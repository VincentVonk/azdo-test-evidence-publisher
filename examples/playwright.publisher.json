{
  "azdo": {
    "tokenEnvVar": "AZDO_TOKEN"
  },
  "settings": {
    "mappingPattern": "TC-(\\d+)",
    "uploadResultEvidenceFor": "failed",
    "duplicateStrategy": "fail"
  },
  "runs": [
    {
      "name": "playwright",
      "resultFormat": "junit",
      "resultFiles": [
        "playwright-report/junit.xml",
        "test-results/**/*.xml"
      ],
      "evidenceFolder": "test-results"
    }
  ]
}
