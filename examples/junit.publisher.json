{
  "azdo": {
    "organization": "https://dev.azure.com/example-org",
    "project": "ExampleProject",
    "planId": 123,
    "suiteId": 456,
    "tokenEnvVar": "AZDO_TOKEN"
  },
  "settings": {
    "mappingPattern": "TC-(\\d+)",
    "allowUnmapped": false,
    "duplicateStrategy": "fail"
  },
  "runs": [
    {
      "name": "junit-regression",
      "resultFormat": "junit",
      "resultFiles": [
        "../tests/fixtures/junit/*.xml"
      ],
      "evidenceFolder": "../tests/fixtures/evidence"
    }
  ]
}
